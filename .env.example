PODCAST_CUTTER_DB_URL=sqlite:///data/podcast_cutter.db
PODCAST_CUTTER_PROJECT_ROOT=.

# Pipeline orchestrator: local (default) or airflow. Airflow credentials are
# required only when this API process uses PIPELINE_ORCHESTRATOR=airflow.
PIPELINE_ORCHESTRATOR=local
AIRFLOW_API_BASE_URL=http://127.0.0.1:8080
AIRFLOW_UI_BASE_URL=http://127.0.0.1:8080
AIRFLOW_DAG_ID=podcast_clip_pipeline
AIRFLOW_API_USERNAME=
AIRFLOW_API_PASSWORD=
AIRFLOW_API_TIMEOUT_SECONDS=10
AIRFLOW_CONTAINER_ROOT=/opt/ai-cutter

# Local transcription:
# TRANSCRIPTION_DEVICE=auto prefers CUDA when available, then falls back to CPU int8
# when CUDA runtime libraries such as cuBLAS/cuDNN cannot be loaded.
# Allowed values: auto, cuda, cpu.
TRANSCRIPTION_DEVICE=auto
TRANSCRIPTION_COMPUTE_TYPE=auto

# Clip transcript boundary reviewer:
# local_stub is deterministic and offline for development/tests.
# gemini makes a real Google Gen AI SDK call for every reviewed clip.
CLIP_REVIEW_MODE=local_stub
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
CLIP_REVIEW_CONTEXT_SECONDS=20.0
# Timeout values are in seconds.
# Maximum duration of one Gemini provider attempt.
GEMINI_REQUEST_TIMEOUT_SECONDS=300
# Maximum duration of the complete project review batch.
GEMINI_BATCH_TIMEOUT_SECONDS=1800
