# Copy this file to orchestration/airflow/.env.airflow and replace every
# change-me value before starting the stack. Keep passwords URL-safe because
# AIRFLOW_DB_PASSWORD is embedded in a PostgreSQL connection URL.
AIRFLOW_API_USERNAME=podcast_admin
AIRFLOW_API_PASSWORD=change-me-api-password
AIRFLOW_DB_PASSWORD=change-me-database-password
AIRFLOW_JWT_SECRET=change-me-at-least-32-random-characters

AIRFLOW_PORT=8080
APP_API_PORT=8010
APP_DATA_HOST_PATH=./data
AIRFLOW_API_TIMEOUT_SECONDS=10

# This controls manual review API calls. An automatic Airflow review task uses
# explicit Gemini mode with no fallback; create the project with auto_review
# disabled for offline pipeline fixtures.
CLIP_REVIEW_MODE=local_stub
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_REQUEST_TIMEOUT_SECONDS=300
GEMINI_BATCH_TIMEOUT_SECONDS=1800
